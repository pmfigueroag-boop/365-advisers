# Plantilla de variables de entorno — 365 Advisers Backend
# Copia este archivo como `.env` y rellena con tus claves reales.
# NUNCA committees el archivo `.env` al repositorio.

GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, single-user):
# DATABASE_URL=sqlite:///advisers.db
# PostgreSQL (recommended for multi-user / production):
DATABASE_URL=postgresql+psycopg://advisers:advisers@localhost:5432/advisers365
