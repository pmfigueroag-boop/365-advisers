# Plantilla de variables de entorno — 365 Advisers Backend
# Copia este archivo como `.env` y rellena con tus claves reales.
# NUNCA commitees el archivo `.env` al repositorio.

GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
TAVILY_API_KEY=your-tavily-api-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, single-user):
# DATABASE_URL=sqlite:///advisers.db
# PostgreSQL (recommended for multi-user / production):
DATABASE_URL=postgresql+psycopg://advisers:advisers@localhost:5432/advisers365

# ─── EDPL: External Data Provider Layer ───────────────────────────────────────

# Market Data
POLYGON_API_KEY=your-polygon-api-key-here
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key-here
TWELVE_DATA_API_KEY=your-twelve-data-api-key-here

# Fundamental Data
FMP_API_KEY=your-fmp-api-key-here
FINNHUB_API_KEY=your-finnhub-api-key-here

# Macro Data
FRED_API_KEY=your-fred-api-key-here
# World Bank — no key needed
# IMF — no key needed

# Sentiment Data
NEWS_API_KEY=your-news-api-key-here
STOCKTWITS_API_KEY=                    # optional, higher rate limit
SANTIMENT_API_KEY=                     # required for crypto sentiment

# Alternative Data (commercial — require enterprise licenses)
SIMILARWEB_API_KEY=                    # enterprise only ($10K+/yr)
THINKNUM_API_KEY=                      # commercial contract required

# Regulatory / Filings
SEC_EDGAR_EMAIL=your-email@company.com
QUIVER_API_KEY=your-quiver-api-key-here

# Options / Volatility
CBOE_API_KEY=                          # public data, key optional
OPTIONMETRICS_API_KEY=                 # academic/enterprise ($5K+/yr)
